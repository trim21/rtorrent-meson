{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>trim21/renovate-config",
    "local>trim21/renovate-config:monthly"
  ],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "groupName": "src",
      "matchPackageNames": [
        "submodules"
      ]
    }
  ]
}
